generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("STAFF")
  avatar    String?
  createdAt DateTime @default(now())
  @@map("users")
}

model Patient {
  id               String          @id @default(cuid())
  mrn              String          @unique
  fullName         String
  dob              String
  gender           String
  phone            String
  email            String?
  address          String?
  bloodGroup       String?
  referralSource   String?
  department       String?
  emergencyContact String?
  emergencyPhone   String?
  allergies        String?
  chronicConditions String?
  insuranceProvider String?
  insuranceNumber   String?
  notes            String?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  records          MedicalRecord[]
  @@map("patients")
}

model MedicalRecord {
  id                  String   @id @default(cuid())
  patientId           String
  patient             Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visitDate           String
  visitType           String   @default("OPD")
  consultantDoctor    String
  department          String?
  chiefComplaint      String?
  diagnosis           String?
  prescriptionDetails String?
  labOrders           String?
  vitalSigns          String?
  billingAmount       Float    @default(0)
  billingStatus       String   @default("PENDING")
  isHistorical        Boolean  @default(false)
  followUpDate        String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  @@map("medical_records")
}
